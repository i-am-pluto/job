{
  "manifest_version": 3,
  "name": "ATS Control Suite",
  "version": "1.0.0",
  "description": "Drives the user's logged-in ATS session (Workday, Greenhouse, Lever) for automated job applications. Connects out to a local WebSocket bridge and runs commands against the live DOM.",
  "permissions": ["scripting", "tabs", "storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://*.myworkdayjobs.com/*",
    "https://*.wd1.myworkdayjobs.com/*",
    "https://*.wd5.myworkdayjobs.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.myworkdayjobs.com/*",
        "https://*.wd1.myworkdayjobs.com/*",
        "https://*.wd5.myworkdayjobs.com/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*"
      ],
      "js": ["selectors/workday.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
